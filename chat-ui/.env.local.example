# ============================================
# Claude AI (via Vertex AI)
# ============================================
# Uses GCP Application Default Credentials — no API key needed
# Optional: override model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# ============================================
# n8n-mcp Backend
# ============================================
# URL of the running n8n-mcp service
# Local Docker: http://localhost:3001
# Cloud Run: https://n8n-mcp-claude-xxx-uc.a.run.app
MCP_SERVICE_URL=http://localhost:3001

# Same AUTH_TOKEN used for n8n-mcp (from root .env)
MCP_AUTH_TOKEN=your-auth-token-here

# ============================================
# Local Development Auth Bypass
# ============================================
# When running locally (without Google IAP), this email is used as the mock user.
# Remove or leave empty in production — IAP headers take over.
MOCK_USER_EMAIL=dev@example.com

# ============================================
# Firestore (local emulator for development)
# ============================================
# Uncomment to use local Firestore emulator instead of production
# FIRESTORE_EMULATOR_HOST=localhost:8080

# In Cloud Run, Firebase Admin uses Application Default Credentials automatically.
# For local dev WITHOUT the emulator, set the path to a service account key:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# ============================================
# n8n Cloud Instance (direct workflow deployment)
# ============================================
# URL and API key for the Guesty n8n instance
N8N_API_URL=https://guesty.app.n8n.cloud
N8N_API_KEY=your-n8n-api-key-here

# ============================================
# Hub × n8n-builder integration (callbacks)
# ============================================
# Base URL for the Hub Supabase Edge Functions (the route paths
# n8n-conversation-callback and n8n-builder-callback are appended in code).
# Leave empty to disable Hub callbacks entirely.
HUB_CALLBACK_URL=https://ilhlkseqwparwdwhzcek.supabase.co/functions/v1
# Shared secret with the Hub Edge Functions. Same value as the Supabase project's
# HUB_CALLBACK_SECRET secret. Generate via: openssl rand -hex 32.
HUB_CALLBACK_SECRET=your-shared-secret-here

# ============================================
# Google OAuth (post-IAP, app-level identity)
# ============================================
# Web OAuth 2.0 Client ID for chat-ui. Created in agentic-workflows-485210 via
# Cloud Console (Credentials → Create OAuth client → Web application). The
# IAP-flavored variant from `gcloud iap oauth-clients create` doesn't allow
# editing Authorized JS Origins, so a regular Web client is required for GIS.
# Frontend GIS uses this for sign-in; server verifies ID token audience.
# Not secret (appears in browser-side payload as the GIS client_id).
GOOGLE_OAUTH_CLIENT_ID=535171325336-lohp54d4kp8npumfp8bgm4bttnlg6v48.apps.googleusercontent.com
# Comma-separated allowed Workspace domains. Defaults to
# guesty.com,rentalsunited.com when unset.
# ALLOWED_OAUTH_DOMAINS=guesty.com,rentalsunited.com
