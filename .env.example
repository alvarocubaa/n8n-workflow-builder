# n8n-mcp-claude Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Authentication (REQUIRED for HTTP mode)
# ============================================
# Generate with: openssl rand -base64 32
AUTH_TOKEN=your-secure-token-here

# ============================================
# n8n Cloud Configuration
# ============================================
# Your n8n instance URL (Cloud or self-hosted)
N8N_API_URL=https://your-instance.app.n8n.cloud/

# API Key from n8n Settings -> API
N8N_API_KEY=your-n8n-api-key-here

# ============================================
# Server Configuration
# ============================================
MCP_MODE=http
LOG_LEVEL=info

# ============================================
# Optional: Telemetry (uncomment to disable)
# ============================================
# N8N_MCP_TELEMETRY_DISABLED=true

# ============================================
# chat-ui (new service)
# ============================================
# Get a Gemini API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Local dev mock user (bypasses Google IAP)
MOCK_USER_EMAIL=dev@example.com
