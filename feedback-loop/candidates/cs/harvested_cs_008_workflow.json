        "sqlQuery": "SELECT account_id, account_name, max_paid_listings, churn_reason FROM `guesty-data.csm.csm_churn_report` WHERE account_id = '={{ $node['Get Opportunity Details'].json.records[0].Account.Guesty_Admin_ID__c }}' LIMIT 1"
      },
      "credentials": {
        "googleApi": {
          "id": "VQ7CU7dKViVcv8Ah",
          "name": "Google Service Account n8n-ai-cx-read"
