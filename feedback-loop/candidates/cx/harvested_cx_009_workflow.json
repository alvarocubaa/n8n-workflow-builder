{
  "name": "Monthly Strategy Reservations - Data Pull",
  "nodes": [
    {
      "id": "a3f1c2d4-8e5b-4a7c-9f0d-1b2e3c4d5e6f",
      "name": "1st of Month Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        240,
        300
      ],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 0 1 * *"
            }
          ]
        }
      }
    },
    {
      "id": "b7e2d3f5-9a6c-4b8d-0e1f-2c3d4e5f6a7b",
      "name": "BigQuery - Reservations",
      "type": "n8n-nodes-base.googleBigQuery",
      "typeVersion": 2,
      "position": [
        480,
        300
      ],
      "parameters": {
        "projectId": "guesty-data",
        "sqlQuery": "SELECT\n  month,\n  country,\n  package,\n  \"All Channels\" AS channel,\n  SUM(gbv)                          AS GBV,\n  SUM(gbv) / SUM(nights)            AS ADR,\n  COUNT(DISTINCT reservation_id)    AS Reservations,\n  COUNT(DISTINCT paid_listing_id)   AS Paid_Listings,\n  AVG(avg_lead_time)                AS AVG_Lead_Time,\n  SUM(nights)                       AS Nights,\n  AVG(nights)                       AS AVG_LOS,\n  SUM(bedrooms)                     AS Bedrooms\n\nFROM `guesty-data.strategy.reservations`\n\nWHERE\n  month BETWEEN DATE_SUB(DATE_TRUNC(CURRENT_DATE, MONTH), INTERVAL 12 MONTH)\n            AND DATE_SUB(DATE_TRUNC(CURRENT_DATE, MONTH), INTERVAL 1 MONTH)\n\n  AND country IN (\n    'United Kingdom',\n    'Australia',\n    'New Zealand',\n    'France',\n    'Canada',\n    'Mexico',\n    'Italy',\n    'Spain',\n    'United Arab Emirates',\n    'Germany',\n    'Greece',\n    'Brazil',\n    'Portugal',\n    'Croatia',\n    'India',\n    'Colombia',\n    'Thailand',\n    'Argentina',\n    'South Africa'\n  )\n\nGROUP BY ALL\nORDER BY 1 DESC",
        "options": {}
      },
      "credentials": {
        "googleApi": {
          "id": "h7fJ82YhtOnUL58u",
          "name": "Google BigQuery - N8N Service Account"
        }
      }
    },
    {
      "id": "c8f3e4a6-0b7d-4c9e-1f2a-3d4e5f6a7b8c",
      "name": "Clear Sheet Data",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        720,
        300
      ],
      "parameters": {
