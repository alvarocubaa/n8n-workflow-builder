        "documentId": {
          "mode": "url",
          "value": "https://docs.google.com/spreadsheets/d/1SGmRXmS0K9437fI_5rzl8zIoIVRkNtTiskZAk9Zy_Ac/edit"
        },
        "sheetName": {
          "mode": "name",
          "value": "Data pull"
        },
        "clearType": "sheet",
        "options": {}
