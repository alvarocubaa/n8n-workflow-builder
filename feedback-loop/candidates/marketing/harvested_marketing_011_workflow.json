    {
      "id": "cc3d4e5f-6a7b-8c9d-0e1f-2a3b4c5d6e7f",
      "name": "Pivot Into Event Matrix",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2420,
        300
      ],
      "parameters": {
        "jsCode": "const rows = $input.first().json.all_rows;\nconst runDate = rows[0]?.run_date || '';\n\n// Get unique competitor names\nconst competitors = [...new Set(rows.map(r => r.competitor_name))];\n\n// Build event map keyed by event_name\nconst eventMap = {};\nfor (const row of rows) {\n  const key = row.event_name;\n  if (!eventMap[key]) {\n    eventMap[key] = {\n      'Run Date': runDate,\n      'Event Name': row.event_name,\n      'Event Date': row.event_date,\n      'City': row.city,\n      'State': row.state,\n      'Country': row.country,\n      'Event URL': row.event_url,\n      'Guesty Attending?': row.guesty_attending\n    };\n    for (const c of competitors) {\n      eventMap[key][c] = 'X';\n    }\n  }\n  eventMap[key][row.competitor_name] = 'V';\n  if (row.guesty_attending === 'Yes') {\n    eventMap[key]['Guesty Attending?'] = 'Yes';\n  }\n  if (!eventMap[key]['Event URL'] || eventMap[key]['Event URL'] === '') {\n    eventMap[key]['Event URL'] = row.event_url;\n  }\n}\n\nreturn Object.values(eventMap).map(row => ({ json: row }));"
      }
    },
