    {
      "id": "c9f1e2a3-6b5d-4c4e-d3f4-9a0b1c2d3e4f",
      "name": "AI Event Extractor",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        1320,
        300
      ],
      "parameters": {
        "promptType": "define",
        "text": "=Competitor: {{ $json['Competitor Name'] }}\n\nEVENTS WEBSITE CONTENT:\n{{ $('Scrape Events Website').item.json.data.markdown }}\n\nLINKEDIN PAGE CONTENT:\n{{ $('Scrape LinkedIn Page').item.json.data.markdown }}\n\nGUESTY EVENTS LIST:\n{{ $('Get Guesty Events').all().map(e => e.json['Event Name']).join(', ') }}",
        "messages": {
          "messageValues": [
            {
              "type": "SystemMessagePromptTemplate",
              "message": "You are an event intelligence analyst. Extract all THIRD-PARTY events this competitor is attending, sponsoring, speaking at, or exhibiting at. STRICT EXCLUSION RULES - do NOT include: (1) webinars hosted or owned by the competitor themselves, (2) product demos or product launches run by the competitor, (3) internal company events, training sessions, or town halls, (4) any event where the competitor is the sole organizer or host. ONLY include events where the competitor is a participant, sponsor, speaker, or exhibitor alongside other companies. For each qualifying event found, check if it appears in the Guesty Events List. Return ONLY a valid JSON array, no markdown, no code fences. Each item must have these exact fields: event_name (string), event_date (string, use Unknown if not found), city (string, the city where the event takes place, use Unknown if not found, use Virtual if online), state (string, the state or province, use Unknown if not applicable or not found, use N/A for non-US events), country (string, the country where the event takes place, use Unknown if not found, use Online if virtual), event_url (string, the direct URL to the event website or registration page - look for hyperlinks in the scraped content associated with the event name, use the competitor events page URL as fallback if no specific event URL is found), source (either Events Website or LinkedIn or Both), guesty_attending (either Yes or No or Unknown - Yes only if the event name closely matches one in the Guesty Events List), photo_urls (array of image URLs found on LinkedIn related to this event, empty array if none). If no qualifying events are found, return an empty array []."
            },
            {
              "type": "HumanMessagePromptTemplate",
              "message": "Extract all third-party events for competitor: {{ $json['Competitor Name'] }}"
            }
          ]
        },
        "hasOutputParser": false
      }
    },
