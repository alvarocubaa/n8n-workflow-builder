      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  const linkColumn = item.json.column_values.find(col => col.type === 'link');\n  let gdrive_url = '';\n  let gdrive_id = '';\n  if (linkColumn && linkColumn.value) {\n    const parsedValue = JSON.parse(linkColumn.value);\n    gdrive_url = parsedValue.url;\n    const match = gdrive_url.match(/\\/d\\/([a-zA-Z0-9_-]+)/);\n    if (match && match[1]) {\n      gdrive_id = match[1];\n    }\n  }\n  item.json.gdrive_url = gdrive_url;\n  item.json.gdrive_id = gdrive_id;\n}\nreturn $input.all();"
      },
