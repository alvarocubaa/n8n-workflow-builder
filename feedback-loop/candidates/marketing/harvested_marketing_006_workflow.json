    {
      "id": "d3a1f6e9-45b0-4c27-a08d-9f0a1b2c3d4e",
      "name": "Parse Domain Metrics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        300
      ],
      "parameters": {
        "jsCode": "// Semrush domain_ranks returns pipe-delimited text\n// Columns: Db|Dn|Rk|Or|Ot|Oc|Ad|At|Ac|Sh|Sv|Sr|Xn\n// Rk=Domain Rank, Or=Organic Keywords, Ot=Organic Traffic\n\nconst raw = $input.item.json.data || '';\nconst lines = raw.trim().split('\\n');\n\nif (lines.length < 2) {\n  return [{ json: { Date: new Date().toISOString().split('T')[0], DomainRank: 0, OrganicTraffic: 0, OrganicKeywords: 0 } }];\n}\n\nconst headers = lines[0].split(';');\nconst values = lines[1].split(';');\n\nconst row = {};\nheaders.forEach((h, i) => { row[h.trim()] = values[i] ? values[i].trim() : ''; });\n\nreturn [{\n  json: {\n    Date: new Date().toISOString().split('T')[0],\n    DomainRank: parseInt(row['Rk'] || row['rk'] || 0, 10),\n    OrganicTraffic: parseInt(row['Ot'] || row['ot'] || 0, 10),\n    OrganicKeywords: parseInt(row['Or'] || row['or'] || 0, 10)\n  }\n}];"
      }
    },
    {
      "id": "e4b2a7f0-56c1-4d38-b19e-0a1b2c3d4e5f",
      "name": "Parse Keyword Rankings",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        480
      ],
      "parameters": {
        "jsCode": "// Semrush domain_organic returns semicolon-delimited text\n// Columns: Ph|Po|Nq|Cp|Ur|Tr|Tc|Co|Nr|Td\n// Ph=Keyword, Po=Position, Nq=Search Volume, Tr=Traffic\n\nconst raw = $input.item.json.data || '';\nconst lines = raw.trim().split('\\n');\n\nif (lines.length < 2) {\n  return [{ json: { Keyword: 'N/A', Position: 0, SearchVolume: 0, Traffic: 0 } }];\n}\n\nconst headers = lines[0].split(';');\nconst results = [];\n\nfor (let i = 1; i < lines.length; i++) {\n  if (!lines[i].trim()) continue;\n  const values = lines[i].split(';');\n  const row = {};\n  headers.forEach((h, idx) => { row[h.trim()] = values[idx] ? values[idx].trim() : ''; });\n  results.push({\n    json: {\n      Date: new Date().toISOString().split('T')[0],\n      Keyword: row['Ph'] || '',\n      Position: parseInt(row['Po'] || 0, 10),\n      SearchVolume: parseInt(row['Nq'] || 0, 10),\n      Traffic: parseInt(row['Tr'] || 0, 10)\n    }\n  });\n}\n\nreturn results;"
      }
    },
