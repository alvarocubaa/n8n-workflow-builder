    {
      "id": "e0b8a3f6-12c7-4d9e-b75e-6a7b8c9d0e1f",
      "name": "Build Slack Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        480
      ],
      "parameters": {
        "jsCode": "// Collect all items - first item is domain metrics, rest are top 5 keywords\nconst items = $input.all();\n\n// Find the domain metrics item (has DomainRank field)\nconst metricsItem = items.find(i => i.json.DomainRank !== undefined);\nconst keywordItems = items.filter(i => i.json.Keyword !== undefined);\n\nconst rank = metricsItem ? metricsItem.json.DomainRank : 'N/A';\nconst traffic = metricsItem ? metricsItem.json.OrganicTraffic : 'N/A';\nconst keywords = metricsItem ? metricsItem.json.OrganicKeywords : 'N/A';\nconst date = metricsItem ? metricsItem.json.Date : new Date().toISOString().split('T')[0];\n\nlet kwLines = '';\nkeywordItems.forEach((item, idx) => {\n  const kw = item.json.Keyword || '';\n  const pos = item.json.Position || 0;\n  const vol = item.json.SearchVolume || 0;\n  kwLines += (idx + 1) + '. *' + kw + '* -- Pos: #' + pos + ' | Vol: ' + vol.toLocaleString() + '\\n';\n});\n\nconst message = ':bar_chart: *Guesty.com Weekly SEO Report* (' + date + ')\\n\\n' +\n  '*Domain Overview*\\n' +\n  '- Domain Rank: *' + rank + '*\\n' +\n  '- Organic Traffic: *' + (typeof traffic === 'number' ? traffic.toLocaleString() : traffic) + '*\\n' +\n  '- Organic Keywords: *' + (typeof keywords === 'number' ? keywords.toLocaleString() : keywords) + '*\\n\\n' +\n  '*Top 5 Keywords by Search Volume*\\n' +\n  kwLines +\n  '\\n_Data sourced from Semrush. Full report in Google Sheets._';\n\nreturn [{ json: { slackMessage: message } }];"
      }
    },
