    {
      "parameters": {
        "jsCode": "/**\n * Resolve video_id from creative response.\n * Outputs one item per ad that HAS a video_id, so the next HTTP node can fetch the source URL.\n * Passes through all creative data for non-video ads too (video_id will be empty).\n */\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const creative = item.json.creative || {};\n  const videoId = creative.video_id\n    || (creative.object_story_spec && creative.object_story_spec.video_data && creative.object_story_spec.video_data.video_id)\n    || '';\n\n  results.push({\n    json: {\n      ad_id: item.json.id || item.json.ad_id || '',\n      creative_id: creative.id || '',\n      creative_name: creative.name || '',\n      creative_body: creative.body\n        || (creative.object_story_spec && creative.object_story_spec.video_data && creative.object_story_spec.video_data.text)\n        || (creative.object_story_spec && creative.object_story_spec.link_data && creative.object_story_spec.link_data.message)\n        || (creative.asset_feed_spec && creative.asset_feed_spec.bodies && creative.asset_feed_spec.bodies[0] && creative.asset_feed_spec.bodies[0].text)\n        || '',\n      creative_link: (creative.object_story_spec && creative.object_story_spec.link_data && creative.object_story_spec.link_data.link)\n        || (creative.object_story_spec && creative.object_story_spec.video_data && creative.object_story_spec.video_data.call_to_action && creative.object_story_spec.video_data.call_to_action.value && creative.object_story_spec.video_data.call_to_action.value.link)\n        || (creative.asset_feed_spec && creative.asset_feed_spec.link_urls && creative.asset_feed_spec.link_urls[0] && creative.asset_feed_spec.link_urls[0].website_url)\n        || '',\n      image_url_hires: creative.image_url || '',\n      thumbnail_url: creative.thumbnail_url || '',\n      video_id: videoId,\n      is_video: videoId !== ''\n    }\n  });\n}\n\nreturn results;"
      },
