    {
      "parameters": {
        "jsCode": "/**\n * Resolve final media URL:\n * - If video: use source (MP4) from video API, fallback to picture (thumbnail)\n * - If image: use full-res image_url_hires, fallback to thumbnail_url\n */\nconst items = $input.all();\n\nreturn items.map(function(item) {\n  const d = item.json;\n  let finalMediaUrl = '';\n\n  if (d.is_video) {\n    // d.source comes from the merged video API response\n    finalMediaUrl = d.source || d.picture || d.thumbnail_url || '';\n  } else {\n    finalMediaUrl = d.image_url_hires || d.thumbnail_url || '';\n  }\n\n  return {\n    json: {\n      ad_id: d.ad_id || d.id || '',\n      creative_id: d.creative_id || '',\n      creative_body: d.creative_body || '',\n      creative_link: d.creative_link || '',\n      media_url: finalMediaUrl,\n      is_video: d.is_video || false\n    }\n  };\n});"
      },
