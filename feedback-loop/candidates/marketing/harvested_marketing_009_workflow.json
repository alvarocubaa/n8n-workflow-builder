    {
      "parameters": {
        "jsCode": "/**\n * Guesty Ad-Tech Transformation v2\n * Upgrades: adset_name, exact action_type strings, asset_type, usp, action_values for MQL value\n */\n\nconst items = $input.all();\nconst rawData = items[0].json.data ? items[0].json.data : items.map(item => item.json);\n\nconst adAggregator = {};\n\n// --- USP Classifier ---\nfunction classifyAssetType(adName) {\n  if (!adName) return 'Product Ad';\n  const n = adName.toLowerCase();\n  if (n.includes('ugc')) return 'UGC';\n  if (n.includes('testimonial') || n.includes('guestimonial') || n.includes('mntn_testimonial')) return 'Testimonial';\n  return 'Product Ad';\n}\n\n// --- USP Extractor: reads ad_name tokens after known prefixes ---\nfunction extractUsp(adName, adBody) {\n  if (!adName) return '';\n  const n = adName.toLowerCase();\n  // Revenue / Growth / Occupancy / Reviews / Numbers / Peace / Fear / All-in-one\n  if (n.includes('revenue')) return 'Revenue Growth';\n  if (n.includes('growth')) return 'Portfolio Growth';\n  if (n.includes('occupancy')) return 'Occupancy Boost';\n  if (n.includes('review')) return 'Social Proof - Reviews';\n  if (n.includes('numbers') || n.includes('33') || n.includes('35')) return 'Social Proof - Stats';\n  if (n.includes('peace') || n.includes('peace_of_mind')) return 'Peace of Mind';\n  if (n.includes('fear')) return 'Fear of Missing Out';\n  if (n.includes('all_in_one') || n.includes('allinone')) return 'All-in-One Platform';\n  if (n.includes('trust_accounting') || n.includes('accounting')) return 'Trust Accounting';\n  if (n.includes('copilot')) return 'AI Copilot';\n  if (n.includes('before_after')) return 'Before vs After';\n  if (n.includes('quotes')) return 'Customer Quote';\n  if (n.includes('auto_check') || n.includes('check_in')) return 'Automated Check-in';\n  if (n.includes('text ad') || n.includes('graphic ad') || n.includes('headshots')) return 'Event / Webinar';\n  // Fallback: use first meaningful token from ad_name\n  return adName.split('_')[0] || 'Other';\n}\n\n// PHASE 1: Aggregate by Ad ID + Country\nfor (const row of rawData) {\n  const adId = row.ad_id;\n  const country = row.country || 'Unknown';\n  const campName = row.campaign_name ? row.campaign_name.toLowerCase() : '';\n\n  if (!adId) continue;\n\n  let campaignType = 'Prospecting';\n  if (campName.includes('rmkt') || campName.includes('retargeting')) {\n    campaignType = 'Remarketing';\n  } else if (campName.includes('sandbox') || campName.includes('test')) {\n    campaignType = 'Testing';\n  }\n\n  const compositeKey = adId + '_' + country;\n\n  if (!adAggregator[compositeKey]) {\n    adAggregator[compositeKey] = {\n      sheet_match_key: compositeKey,\n      ad_id: adId,\n      adset_id: row.adset_id || '',\n      adset_name: row.adset_name || '',\n      country: country,\n      campaign_type: campaignType,\n      campaign_name: row.campaign_name || '',\n      ad_name: row.ad_name || '',\n      asset_type: classifyAssetType(row.ad_name),\n      usp: extractUsp(row.ad_name, ''),\n      total_spend: 0,\n      total_impressions: 0,\n      total_clicks: 0,\n      total_demo_requests: 0,\n      total_mql: 0,\n      total_sql: 0,\n      total_mql_value: 0,\n      weekly_trend: []\n    };\n  }\n\n  const weekSpend = parseFloat(row.spend) || 0;\n  const weekImpressions = parseInt(row.impressions) || 0;\n  let weekClicks = parseInt(row.clicks) || 0;\n  let weekDemo = 0;\n  let weekMql = 0;\n  let weekSql = 0;\n  let weekMqlValue = 0;\n\n  // Extract from actions (link clicks override)\n  if (row.actions && Array.isArray(row.actions)) {\n    row.actions.forEach(function(action) {\n      if (action.action_type === 'link_click') {\n        weekClicks = parseInt(action.value) || weekClicks;\n      }\n    });\n  }\n\n  // Extract from conversions -- exact Meta pixel custom event strings\n  if (row.conversions && Array.isArray(row.conversions)) {\n    row.conversions.forEach(function(conv) {\n      const t = conv.action_type || '';\n      if (t === 'offsite_conversion.fb_pixel_custom.Request Demo Submission') {\n        weekDemo = parseInt(conv.value) || 0;\n      } else if (t === 'offsite_conversion.fb_pixel_custom.Combined MQL') {\n        weekMql = parseInt(conv.value) || 0;\n      } else if (t === 'offsite_conversion.fb_pixel_custom.Combined SQL') {\n        weekSql = parseInt(conv.value) || 0;\n      }\n    });\n  }\n\n  // Extract MQL value from action_values\n  if (row.action_values && Array.isArray(row.action_values)) {\n    row.action_values.forEach(function(val) {\n      if (val.action_type === 'offsite_conversion.fb_pixel_custom.Combined MQL') {\n        weekMqlValue = parseFloat(val.value) || 0;\n      }\n    });\n  }\n\n  adAggregator[compositeKey].total_spend += weekSpend;\n  adAggregator[compositeKey].total_impressions += weekImpressions;\n  adAggregator[compositeKey].total_clicks += weekClicks;\n  adAggregator[compositeKey].total_demo_requests += weekDemo;\n  adAggregator[compositeKey].total_mql += weekMql;\n  adAggregator[compositeKey].total_sql += weekSql;\n  adAggregator[compositeKey].total_mql_value += weekMqlValue;\n\n  if (weekSpend > 0) {\n    adAggregator[compositeKey].weekly_trend.push({\n      date: row.date_start,\n      ctr: weekImpressions > 0 ? parseFloat(((weekClicks / weekImpressions) * 100).toFixed(2)) : 0,\n      cr_click_to_mql: weekClicks > 0 ? parseFloat(((weekMql / weekClicks) * 100).toFixed(2)) : 0\n    });\n  }\n}\n\nconst results = [];\n\n// PHASE 2: Calculate ratios\nfor (const key in adAggregator) {\n  const ad = adAggregator[key];\n\n  if (ad.total_spend < 50 || ad.total_clicks < 20) continue;\n\n  ad.ctr_hook = ad.total_impressions > 0\n    ? parseFloat(((ad.total_clicks / ad.total_impressions) * 100).toFixed(2)) : 0;\n\n  ad.cr_click_to_demo = ad.total_clicks > 0\n    ? parseFloat(((ad.total_demo_requests / ad.total_clicks) * 100).toFixed(2)) : 0;\n\n  ad.cr_click_to_mql = ad.total_clicks > 0\n    ? parseFloat(((ad.total_mql / ad.total_clicks) * 100).toFixed(2)) : 0;\n\n  ad.cr_mql_to_sql = ad.total_mql > 0\n    ? parseFloat(((ad.total_sql / ad.total_mql) * 100).toFixed(2)) : 0;\n\n  ad.avg_mql_value = ad.total_mql > 0\n    ? parseFloat((ad.total_mql_value / ad.total_mql).toFixed(2)) : 0;\n\n  ad.weekly_trend.sort(function(a, b) { return new Date(a.date) - new Date(b.date); });\n\n  results.push({ json: ad });\n}\n\nreturn results;"
      },
