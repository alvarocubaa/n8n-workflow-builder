          }
        ]
      ]
    },
    "Translate to French": {
      "main": [
        [
          {
            "node": "Build FR Title",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Build FR Title": {
      "main": [
        [
          {
            "node": "Create FR Doc",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Create FR Doc": {
      "main": [
        [
          {
            "node": "Write Translation to Doc",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Write Translation to Doc": {
      "main": [
        [
          {
            "node": "Notify Slack",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}