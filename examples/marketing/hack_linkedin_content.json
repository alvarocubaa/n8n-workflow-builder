              "id": "assign-tl-1",
              "name": "Variation Type",
              "type": "string",
              "value": "Thought Leadership Hook"
            },
            {
              "id": "assign-tl-2",
              "name": "Post Text",
              "type": "string",
              "value": "={{ $json.text.includes('HASHTAGS:') ? $json.text.split('HASHTAGS:')[0].replace('POST TEXT:', '').trim() : $json.text.trim() }}"
            },
            {
              "id": "assign-tl-3",
              "name": "Hashtags",
              "type": "string",
              "value": "={{ $json.text.includes('HASHTAGS:') ? $json.text.split('HASHTAGS:')[1].trim() : '' }}"
            },
            {
              "id": "assign-tl-4",
              "name": "Character Count",
              "type": "number",
              "value": "={{ ($json.text.includes('HASHTAGS:') ? $json.text.split('HASHTAGS:')[0].replace('POST TEXT:', '').trim() : $json.text.trim()).length }}"
            }
          ]
        }
