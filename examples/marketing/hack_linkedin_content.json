    {
      "id": "3d594a5e-1b2f-4c8a-9e3d-6f7a8b9c0d1e",
      "name": "Gemini - Thought Leadership",
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1.1,
      "position": [
        480,
        80
      ],
      "parameters": {
        "resource": "text",
        "operation": "message",
        "modelId": {
          "mode": "id",
          "value": "models/gemini-2.5-flash"
        },
        "messages": {
          "values": [
            {
              "role": "user",
              "content": "=You are a LinkedIn content expert. Based on the following article, write a thought-leadership hook post for LinkedIn.\n\nRequirements:\n- Under 200 words\n- Start with a bold, attention-grabbing hook sentence\n- Share a strong opinion or insight\n- End with a question to drive engagement\n- Include exactly 3 relevant hashtags at the end\n\nFormat your response EXACTLY as:\nPOST TEXT:\n[the post text here]\n\nHASHTAGS:\n[hashtag1] [hashtag2] [hashtag3]\n\nARTICLE:\n{{ $json.body }}"
            }
          ]
        },
        "simplify": true,
        "options": {
          "maxOutputTokens": 600,
          "systemMessage": "You are a professional LinkedIn content strategist for Guesty, a property management platform for short-term rental operators."
        }
      },
      "credentials": {
        "googlePalmApi": {
          "id": "LL8fLgZSrUn8oZtV",
          "name": "Google Gemini Guesty n8n Marketing"
        }
      }
    },
    {
      "id": "a1b4c7d2-e5f8-4a3b-9c6d-2e1f0a3b4c5d",
      "name": "Gemini - Data Driven",
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1.1,
      "position": [
        480,
        300
      ],
      "parameters": {
        "resource": "text",
        "operation": "message",
        "modelId": {
          "mode": "id",
          "value": "models/gemini-2.5-flash"
        },
        "messages": {
          "values": [
            {
              "role": "user",
              "content": "=You are a LinkedIn content expert. Based on the following article, write a data-driven insight post for LinkedIn.\n\nRequirements:\n- Lead with a compelling data-backed or insight-driven headline\n- Use bullet points (3-5 bullets) to present key data points or insights from the article\n- End with a clear takeaway or call to action\n- Include exactly 3 relevant hashtags at the end\n\nFormat your response EXACTLY as:\nPOST TEXT:\n[the post text here]\n\nHASHTAGS:\n[hashtag1] [hashtag2] [hashtag3]\n\nARTICLE:\n{{ $json.body }}"
            }
          ]
        },
        "simplify": true,
        "options": {
          "maxOutputTokens": 700,
          "systemMessage": "You are a professional LinkedIn content strategist for Guesty, a property management platform for short-term rental operators."
        }
      },
      "credentials": {
        "googlePalmApi": {
          "id": "LL8fLgZSrUn8oZtV",
          "name": "Google Gemini Guesty n8n Marketing"
        }
      }
    },
    {
      "id": "b2c5d8e3-f6a9-4b4c-0d7e-3f2a1b4c5d6e",
      "name": "Gemini - Storytelling",
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1.1,
      "position": [
        480,
        520
      ],
      "parameters": {
        "resource": "text",
        "operation": "message",
        "modelId": {
          "mode": "id",
          "value": "models/gemini-2.5-flash"
        },
        "messages": {
          "values": [
            {
              "role": "user",
              "content": "=You are a LinkedIn content expert. Based on the following article, write a storytelling post with a personal angle for LinkedIn.\n\nRequirements:\n- Open with a personal anecdote or relatable scenario inspired by the article's theme\n- Weave in the key message naturally through the story\n- Make it feel authentic and human, written in first person\n- End with a personal reflection or call to action\n- Include exactly 3 relevant hashtags at the end\n\nFormat your response EXACTLY as:\nPOST TEXT:\n[the post text here]\n\nHASHTAGS:\n[hashtag1] [hashtag2] [hashtag3]\n\nARTICLE:\n{{ $json.body }}"
            }
          ]
        },
        "simplify": true,
        "options": {
          "maxOutputTokens": 700,
          "systemMessage": "You are a professional LinkedIn content strategist for Guesty, a property management platform for short-term rental operators."
        }
      },
      "credentials": {
        "googlePalmApi": {
          "id": "LL8fLgZSrUn8oZtV",
          "name": "Google Gemini Guesty n8n Marketing"
        }
      }
    },
    {
      "id": "c3d6e9f4-a7b0-4c5d-1e8f-4a3b2c5d6e7f",
      "name": "Format Thought Leadership Row",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        740,
