            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Split Campaign Rows": {
      "main": [
        [
          {
            "node": "Write Metrics to Google Sheet",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}